# H.E.L.P. Center Backend — Environment Variables
# Copy this to .env and fill in your real values
# NEVER commit .env to GitHub

# ── AI (Groq) ─────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM_NAME=H.E.L.P. Center
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── DocuSeal (self-hosted on this VPS) ───────────────────
DOCUSEAL_URL=http://localhost:3002
DOCUSEAL_TOKEN=your_docuseal_api_token

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_SOLO=price_your_solo_plan_price_id
STRIPE_PRICE_PRO=price_your_pro_plan_price_id

# ── App ───────────────────────────────────────────────────
PORT=3001
APP_URL=http://187.124.146.184:8090
